{
  "name": "@klorad/campus",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20 <23",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "NODE_ENV=development NEXT_TELEMETRY_DISABLED=1 next dev -p 3003",
    "build": "next build",
    "start": "next start -p 3003",
    "lint": "next lint --fix --dir app",
    "db:deploy": "pnpm --filter @klorad/prisma prisma migrate deploy",
    "db:generate": "pnpm --filter @klorad/prisma generate",
    "db:migrate": "pnpm --filter @klorad/prisma prisma migrate dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@klorad/design-system": "workspace:^",
    "@klorad/prisma": "workspace:*",
    "@klorad/storage": "workspace:^",
    "@klorad/ui": "workspace:^",
    "@mappedin/mappedin-js": "^6.19.0",
    "@mui/icons-material": "^6.4.2",
    "@mui/material": "^6.4.1",
    "@prisma/client": "^5.22.0",
    "@prisma/extension-accelerate": "^1.0.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@sentry/nextjs": "^10.56.0",
    "@types/node": "^20.11.30",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "culori": "^4.0.2",
    "lucide-react": "^1.16.0",
    "mapbox-gl": "^3.9.4",
    "next": "^15.1.9",
    "next-auth": "5.0.0-beta.30",
    "node-ical": "^0.26.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-toastify": "^11.0.5",
    "resend": "^6.5.0",
    "swr": "^2.3.6",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/culori": "^4.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^9.0.8",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "10.4.20",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.1.9",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.14",
    "typescript": "^5.9.0"
  }
}
