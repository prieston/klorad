{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@klorad/api": ["../packages/api/src/index.ts"],
      "@klorad/core": ["../packages/core/dist/index.d.ts", "../packages/core/dist/index.js"],
      "@klorad/ui": ["../packages/ui/dist/index.d.ts", "../packages/ui/dist/index.js"],
      "@klorad/engine-mapbox": ["../packages/engine-mapbox/dist/index.d.ts", "../packages/engine-mapbox/dist/index.js"],
      "@klorad/engine-three": ["../packages/engine-three/dist/index.d.ts", "../packages/engine-three/dist/index.js"],
      "@klorad/prisma": ["../packages/prisma"]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
