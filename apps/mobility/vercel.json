{
  "buildCommand": "cd ../.. && pnpm vercel:build:mobility",
  "devCommand": "pnpm dev:mobility",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile --prod=false",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_VERCEL_ENV": "production"
  },
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "outputDirectory": ".next"
}
