# Klorad Mobility — local env template.
# Copy to `.env.local` and fill in. Most values can be reused from
# `apps/campus/.env` since Mobility shares the same database +
# auth tier.
#
# `lib/env.ts` validates these at boot. Missing required vars in
# development log a loud warning and use safe fallbacks so the app
# still starts; in production the validator throws.

# ── Boot-blocking ──────────────────────────────────────────────
# Postgres connection string used at runtime by Prisma.
DATABASE_URL="prisma://...accelerate-or-direct..."
# Direct connection used by migrations + Prisma Studio.
DIRECT_DATABASE_URL="postgresql://user:pass@host:port/db?sslmode=require"
# NextAuth session-token signing secret. >= 16 chars.
# Generate one with: openssl rand -base64 32
SECRET="please-change-me-to-a-long-random-string"

# ── Optional features ─────────────────────────────────────────
# At-rest encryption for ATMS credentials (via @klorad/secrets).
# Required to save a live-mode iNET source; fixture mode works
# without it. 64 hex chars used as-is, anything else run through
# scrypt.
SECRETS_KEY=""

# Mapbox public token — operator console map gates on this.
# Get one free from https://mapbox.com → Account → Access tokens.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="pk."

# OAuth providers — at least one is required if visitors need to
# sign in. Same accounts as Campus.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# DigitalOcean Spaces — only needed once tenants start uploading
# logos / source thumbnails. Mobility v1 doesn't reach this.
DO_SPACES_REGION=""
DO_SPACES_ENDPOINT=""
DO_SPACES_BUCKET=""
DO_SPACES_KEY=""
DO_SPACES_SECRET=""
