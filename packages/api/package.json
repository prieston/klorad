{
  "name": "@klorad/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/**",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "dependencies": {
    "@klorad/core": "workspace:*",
    "uuid": "^9.0.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "tsup": "^8.0.0",
    "@types/uuid": "^9.0.8"
  },
  "scripts": {
    "clean": "rimraf dist *.tsbuildinfo",
    "build": "tsup"
  }
}
